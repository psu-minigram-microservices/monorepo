# JWT (shared across all services)
JWT_SECRET=your-secret-key-at-least-32-characters
JWT_ISSUER=Minigram
JWT_AUDIENCE=MinigramClient
JWT_EXPIRATION=15

# Auth service
AUTH_DB_NAME=minigram_auth
AUTH_DB_USER=minigram
AUTH_DB_PASSWORD=minigram
AUTH_DB_PORT=5433

# Chats service
CHATS_DB_NAME=minigram_chats
CHATS_DB_USER=minigram
CHATS_DB_PASSWORD=minigram
CHATS_DB_PORT=5432
CHATS_SPRING_PROFILES=pg

# Profile service
PROFILE_DB_NAME=minigram_profile
PROFILE_DB_USER=minigram
PROFILE_DB_PASSWORD=minigram
PROFILE_DB_PORT=5434

# Service ports
AUTH_SERVICE_PORT=5000
CHATS_SERVICE_PORT=8080
PROFILE_SERVICE_PORT=5001

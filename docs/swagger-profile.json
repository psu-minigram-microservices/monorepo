          "Incoming",
          "Outgoing"
        ],
        "type": "string"
      },
      "tReplyStatus": {
        "enum": [
          "Accepted",
          "Rejected",
          "Blocked"
        ],
        "type": "string"
      },
      "tStatus": {
        "enum": [
          "None",
          "Friend",
          "Blocked"
        ],
        "type": "string"
      }
    },
